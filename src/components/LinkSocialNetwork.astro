---
/**
 * Componente que renderiza un enlace a una red social.
 * @param title - El título del enlace.
 * @param url - La URL del enlace.
 * @param icon - El icono de la red social.
 */
interface Props {
  title: string;
  url: string;
  icon: string | null | undefined;
}

const { title, url, icon } = Astro.props;
---

<a href={url} target="_blank">
  <i class={icon}></i>
  {title}
</a>
